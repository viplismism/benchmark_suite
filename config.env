# Benchmark Configuration for Model Evaluation Suite

# =============================================================================
# LiteLLM Proxy Configuration (routes to Grid AI / Veronica)
# =============================================================================
MODEL_ENDPOINT="http://localhost:8001"
LITELLM_PROXY_KEY="sk-litellm-proxy-key-123"

# Grid AI Configuration
GRID_API_KEY="sk-p12gUkClp1hBP3Yf1zggLA"
GRID_TIMEOUT=7200  # 120 minutes per instance

# =============================================================================
# Terminal-Bench Configuration
# =============================================================================
TERMINAL_BENCH_MODEL="glm-45-air-hs-avinash"   # Model to test (via LiteLLM)
TERMINAL_BENCH_DATASET="terminal-bench-core"
TERMINAL_BENCH_VERSION="0.1.1"
TERMINAL_BENCH_CONCURRENT="8"
TERMINAL_BENCH_TASKS="all"                        #use all for full run
TERMINAL_BENCH_AGENT_TIMEOUT="7200"             # 120 min per task
TERMINAL_BENCH_TEST_TIMEOUT="3600"              # 60 min for tests

# =============================================================================
# τ-Bench Configuration (FULL RUN)
# =============================================================================
TAU_BENCH_DOMAIN="retail"
TAU_BENCH_TASKS="all"
TAU_BENCH_MAX_CONCURRENCY="8"
TAU_BENCH_AGENT_MODEL="kat-dev-hyperswitch-phased-cpt"
TAU_BENCH_USER_MODEL="gpt-4o"

# =============================================================================
# Results & Output
# =============================================================================
RESULTS_DIR="./benchmark_results"
SAVE_INTERMEDIATE_RESULTS=true
VERBOSE_LOGGING=true
DEBUG_MODE=false