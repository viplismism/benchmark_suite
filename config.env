# Benchmark Selection (uncomment to run)
RUN_SWE_BENCH=true
RUN_LIVECODEBENCH=true
RUN_HUMANEVAL_RUST=true
RUN_TAU_BENCH=true
RUN_AIME=true
RUN_TERMINAL_BENCH=true

# Evaluation Parameters
MAX_WORKERS=4
BATCH_SIZE=8
TEMPERATURE=0.0
MAX_TOKENS=2048

# Results Configuration
RESULTS_DIR="./benchmark_results"
SAVE_INTERMEDIATE_RESULTS=true
UPLOAD_TO_TRACKING=false  # Set to true to upload to central tracking

# Performance Targets (for gap calculation)
TARGET_SWE_BENCH=77.2
TARGET_TAU_BENCH=85.4
TARGET_LIVECODEBENCH=2439
TARGET_AIME=95.0
TARGET_TERMINAL_BENCH=54.2

# Notification Settings (optional)
SLACK_WEBHOOK=""
NOTIFY_ON_COMPLETION=false

# Development Settings
DEBUG_MODE=false
VERBOSE_LOGGING=true
SAVE_PROMPTS=true  # Save all prompts for analysis