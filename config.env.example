# ═══════════════════════════════════════════════════════════════════════
#  Benchmark Suite Configuration
# ═══════════════════════════════════════════════════════════════════════
#  Copy this file to config.env and fill in your values:
#    cp config.env.example config.env
# ═══════════════════════════════════════════════════════════════════════

# ─── LiteLLM Proxy ────────────────────────────────────────────────────
MODEL_ENDPOINT="http://localhost:8001"
LITELLM_PROXY_KEY="your-litellm-key"

# ─── HumanEval-Rust ───────────────────────────────────────────────────
HUMANEVAL_MODEL="your-model-name"

# ─── τ-Bench ──────────────────────────────────────────────────────────
TAU_BENCH_DOMAIN="retail"             # "retail" (115 tasks) or "airline" (50 tasks)
TAU_BENCH_TASKS="all"                 # "all" or space-separated IDs: "0 1 2 3 4"
TAU_BENCH_MAX_CONCURRENCY="8"
TAU_BENCH_AGENT_MODEL="your-agent-model"
TAU_BENCH_USER_MODEL="gpt-4o"         # user simulator model

# ─── Terminal-Bench ───────────────────────────────────────────────────
TERMINAL_BENCH_MODEL="your-model-name"
TERMINAL_BENCH_CONCURRENT="8"
TERMINAL_BENCH_TASKS="all"            # "all" or a number for random subset
TERMINAL_BENCH_AGENT_TIMEOUT="7200"
TERMINAL_BENCH_TEST_TIMEOUT="3600"

# ─── Terminal-Bench 2.0 ──────────────────────────────────────────────
TERMINAL_BENCH2_MODEL="openai/your-model-name"
TERMINAL_BENCH2_CONCURRENT="4"
TERMINAL_BENCH2_TASKS="all"
TERMINAL_BENCH2_ATTEMPTS="1"          # official: 5 attempts per task
TERMINAL_BENCH2_TIMEOUT_MULTIPLIER="1.0"
TERMINAL_BENCH2_MAX_RETRIES="0"

# ─── SWE-bench Verified ──────────────────────────────────────────────
#  Requires Docker. ~120GB+ disk space for images.
SWE_BENCH_MODEL="your-model-name"
SWE_BENCH_DATASET="princeton-nlp/SWE-bench_Verified"
SWE_BENCH_MAX_WORKERS="4"
SWE_BENCH_INSTANCE_LIMIT=""           # empty = all 500, or a number
SWE_BENCH_INSTANCE_IDS=""             # comma-separated specific IDs
SWE_BENCH_TIMEOUT="1800"              # per-instance timeout (seconds)
SWE_BENCH_AGENT="simple"              # "simple" (direct LLM) or "sweagent"

# ─── BigCodeBench ─────────────────────────────────────────────────────
BIGCODEBENCH_MODEL="your-model-name"
BIGCODEBENCH_SPLIT="instruct"         # "complete" or "instruct"
BIGCODEBENCH_SUBSET="hard"            # "full" (1140) or "hard" (150)

# ─── GPQA ─────────────────────────────────────────────────────────────
#  Requires HuggingFace token (gated dataset).
GPQA_MODEL="your-model-name"
GPQA_SUBSET="diamond"                 # "diamond" (198), "main" (448), or "extended" (546)
HF_TOKEN="your-huggingface-token"

# ─── General ──────────────────────────────────────────────────────────
RESULTS_DIR="./benchmark_results"
