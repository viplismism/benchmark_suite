MODEL_ENDPOINT="http://localhost:8001"
LITELLM_PROXY_KEY="your-litellm-key"

TERMINAL_BENCH_MODEL="your-model-name"
TERMINAL_BENCH_CONCURRENT="8"
TERMINAL_BENCH_TASKS="all"
TERMINAL_BENCH_AGENT_TIMEOUT="7200"
TERMINAL_BENCH_TEST_TIMEOUT="3600"

TAU_BENCH_DOMAIN="retail"
TAU_BENCH_TASKS="all"
TAU_BENCH_MAX_CONCURRENCY="8"
TAU_BENCH_AGENT_MODEL="your-agent-model"
TAU_BENCH_USER_MODEL="gpt-4o"

# SWE-bench Verified
SWE_BENCH_MODEL="your-model-name"
SWE_BENCH_DATASET="princeton-nlp/SWE-bench_Verified"
SWE_BENCH_MAX_WORKERS="4"
SWE_BENCH_INSTANCE_LIMIT=""         # empty = all 500, or a number
SWE_BENCH_INSTANCE_IDS=""           # comma-separated specific IDs
SWE_BENCH_TIMEOUT="1800"            # per-instance timeout (seconds)
SWE_BENCH_AGENT="simple"            # "simple" (direct LLM) or "sweagent"

# BigCodeBench
BIGCODEBENCH_MODEL="your-model-name"
BIGCODEBENCH_SPLIT="instruct"       # "complete" or "instruct"
BIGCODEBENCH_SUBSET="hard"          # "full" (1140) or "hard" (150)

# GPQA
GPQA_MODEL="your-model-name"
GPQA_SUBSET="diamond"               # "diamond" (198), "main" (448), or "extended" (546)
HF_TOKEN="your-huggingface-token"   # required — GPQA is a gated dataset
