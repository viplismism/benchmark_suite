# Benchmark Configuration - Copy to config.env and fill in your values

# =============================================================================
# LiteLLM Proxy Configuration
# =============================================================================
MODEL_ENDPOINT="http://localhost:8001"
LITELLM_PROXY_KEY="your-litellm-key-here"

# Grid AI Configuration
GRID_API_KEY="your-grid-api-key-here"
GRID_TIMEOUT=7200

# =============================================================================
# Terminal-Bench Configuration
# =============================================================================
TERMINAL_BENCH_MODEL="your-model-name"
TERMINAL_BENCH_DATASET="terminal-bench-core"
TERMINAL_BENCH_VERSION="0.1.1"
TERMINAL_BENCH_CONCURRENT="8"
TERMINAL_BENCH_TASKS="all"
TERMINAL_BENCH_AGENT_TIMEOUT="7200"
TERMINAL_BENCH_TEST_TIMEOUT="3600"

# =============================================================================
# τ-Bench Configuration
# =============================================================================
TAU_BENCH_DOMAIN="retail"
TAU_BENCH_TASKS="all"
TAU_BENCH_MAX_CONCURRENCY="8"
TAU_BENCH_AGENT_MODEL="your-agent-model"
TAU_BENCH_USER_MODEL="gpt-4o"

# =============================================================================
# Results & Output
# =============================================================================
RESULTS_DIR="./benchmark_results"
SAVE_INTERMEDIATE_RESULTS=true
VERBOSE_LOGGING=true
DEBUG_MODE=false
